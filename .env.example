# ---- Base de données PostgreSQL ----
# En local (hors Docker) : localhost. Dans docker-compose, l'hôte est "db".
DATABASE_URL=postgresql://manabu:manabu@localhost:5432/manabu

# ---- Better Auth (authentification auto-hébergée) ----
# Secret de signature/chiffrement (générer : openssl rand -hex 32)
BETTER_AUTH_SECRET=change-me
# URL de base de l'app (origine des cookies/callbacks)
BETTER_AUTH_URL=http://localhost:3000

# ---- Email (pour vérification / réinitialisation de mot de passe) ----
# À renseigner quand l'envoi d'emails sera branché (SMTP ou provider).
# SMTP_URL=

# ---- Application ----
NODE_ENV=development
PORT=3000
