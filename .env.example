# ---- Base de données PostgreSQL ----
# En local (hors Docker) : localhost. Dans docker-compose, l'hôte est "db".
DATABASE_URL=postgresql://manabu:manabu@localhost:5432/manabu

# ---- Clerk (authentification) ----
# Récupérer ces clés sur https://dashboard.clerk.com (une instance par environnement)
# Clé publique, exposée au client (préfixe VITE_ obligatoire pour être injectée côté navigateur)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Clé secrète serveur — ne jamais exposer au client
CLERK_SECRET_KEY=sk_test_xxx
# Secret de signature des webhooks Clerk (pour la synchro user -> user_profiles)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# ---- Application ----
NODE_ENV=development
PORT=3000
